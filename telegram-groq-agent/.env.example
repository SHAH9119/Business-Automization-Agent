# Telegram token from BotFather. This lets your code control the Telegram bot.
TELEGRAM_BOT_TOKEN=

# Groq API key. This lets your code call Groq's AI models.
GROQ_API_KEY=

# Optional comma-separated Groq keys for genuine key failure recovery.
GROQ_API_KEYS=

# AI model used on Groq.
GROQ_MODEL=llama-3.1-8b-instant

# Switch keys before these remaining-quota safety reserves are crossed.
GROQ_MIN_REMAINING_REQUESTS=3
GROQ_MIN_REMAINING_TOKENS=1500

# Gemini API fallback key and model.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# Folder containing clinic/business knowledge files.
BUSINESS_PACK_DIR=../royce-aesthetics-agent

# Folder where local conversations, sessions, and leads are saved.
DATA_DIR=./data

# Optional: your Telegram chat ID for staff/admin alerts.
STAFF_ALERT_CHAT_ID=

# n8n webhook URL — optional; only if you need Calendar/Sheets automation.
# Example: http://localhost:5678/webhook/clinic-lead
N8N_WEBHOOK_URL=

# --- Gmail appointment alerts (free, no n8n) ---
# Use a Google App Password — see docs/gmail-setup.md
GMAIL_SMTP_USER=your@gmail.com
GMAIL_APP_PASSWORD=
STAFF_EMAIL=your@gmail.com
EMAIL_FROM_NAME=Royce Aesthetics Agent

# --- WhatsApp Cloud API (Meta) ---
# Permanent access token from Meta Developer Console > WhatsApp > API Setup.
WHATSAPP_ACCESS_TOKEN=

# Phone number ID from the same WhatsApp API Setup page (not the phone number itself).
WHATSAPP_PHONE_NUMBER_ID=

# Must match the verify token you enter in Meta webhook configuration.
WHATSAPP_VERIFY_TOKEN=business-agent-verify

WHATSAPP_API_VERSION=v21.0

# Optional: staff WhatsApp number in E.164 without + (e.g. 923001234567) for lead alerts.
WHATSAPP_STAFF_PHONE=

# WhatsApp webhook server bind address/port.
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8000

# Set true to test WhatsApp locally without Meta API credentials.
# Replies are returned in POST /webhook response as simulated_replies.
WHATSAPP_SIMULATION_MODE=false
